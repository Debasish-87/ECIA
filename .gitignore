# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files (may contain secrets)
tfplan.*
*.tfplan

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# tfvars with secrets — use -var flag instead
# *.tfvars  ← keep commented so env files stay tracked

# Environment variable files
.env
.env.*
*.env

